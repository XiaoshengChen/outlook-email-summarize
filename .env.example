# Microsoft Entra app credentials
# For personal Outlook accounts, leave OUTLOOK_TENANT_ID=common
OUTLOOK_CLIENT_ID=your-client-id-here
OUTLOOK_CLIENT_SECRET=your-client-secret-here
OUTLOOK_TENANT_ID=common

# Safe defaults for headless OpenClaw deployments
OUTLOOK_AUTH_MODE=device_code
OUTLOOK_READ_ONLY_MODE=true
OUTLOOK_ENABLE_UNSAFE_TOOLS=false

# Optional explicit scope override
# OUTLOOK_SCOPES=offline_access User.Read Mail.Read

# Optional: enable mock responses
USE_TEST_MODE=false
